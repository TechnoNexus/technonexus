{
  "appId": "com.technonexus.app",
  "appName": "technoNexus",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://technonexus.ca",
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0A0A0A",
      "showSpinner": true,
      "androidSpinnerStyle": "large",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#00FFFF"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0A0A0A"
    }
  }
}