{
  "expo": {
    "name": "Nexus Arcade",
    "slug": "nexus-arcade",
    "scheme": "ca.technonexus.nexusarcade",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:technonexus.ca",
        "applinks:www.technonexus.ca"
      ]
    },
    "android": {
      "package": "ca.technonexus.nexusarcade",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "technonexus.ca" },
            { "scheme": "https", "host": "www.technonexus.ca" }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7bfaa2b2-359b-4cd6-8ebc-7cab3ef8dbed"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
